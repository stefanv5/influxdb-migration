# ============================================
# Multi-Source InfluxDB Migration Tool
# ============================================
# Example configuration file

global:
  name: "migration-task-001"
  checkpoint_dir: "./checkpoints"
  report_dir: "./reports"

logging:
  level: "info"                    # debug, info, warn, error
  output: "both"                  # file, console, both
  file:
    path: "logs/migrate.log"      # 日志文件路径
    max_size: 100                 # MB，单个文件最大大小
    max_backups: 10               # 保留的旧日志文件数量
    max_age: 7                    # days，旧日志文件保留天数
    compress: true                # 是否压缩旧日志文件

connection_pool:
  max_open_conns: 10
  max_idle_conns: 5
  conn_max_lifetime: "1h"
  conn_max_idle_time: "30m"

rate_limit:
  enabled: true
  points_per_second: 100000
  burst_size: 50000

migration:
  parallel_tasks: 4
  chunk_size: 10000
  chunk_interval: "100ms"
  max_series_parallel: 2
  source_protection:
    queries_per_second: 10
    rows_per_second: 100000

# InfluxDB to InfluxDB / OpenGemini batch query mode
influx_to_influx:
  enabled: true
  query_mode: "batch"           # "single" or "batch"
  max_series_per_query: 100    # default: 100, max: 1000

retry:
  max_attempts: 3
  initial_delay: "1s"
  max_delay: "60s"
  backoff_multiplier: 2.0

incremental:
  enabled: true
  interval_hours: 24

sources:
  mysql:
    - name: "prod-mysql"
      type: "mysql"
      host: "localhost"
      port: 3306
      user: "root"
      password: "${MYSQL_PASSWORD}"
      database: "metrics"
      charset: "utf8mb4"
      ssl:
        enabled: false
        skip_verify: false
        ca_cert: ""
      pool:
        max_open_conns: 5
        max_idle_conns: 2

  influxdb:
    - name: "prod-influx"
      type: "influxdb"
      version: 2
      url: "https://localhost:8086"
      token: "${INFLUX_TOKEN}"
      org: "my-org"
      bucket: "metrics"
      ssl:
        enabled: true
        skip_verify: false

  tdengine:
    - name: "prod-tdengine"
      type: "tdengine"
      version: "3.x"
      host: "localhost"
      port: 6041
      user: "root"
      password: "${TD_PASSWORD}"
      database: "metrics"
      ssl:
        enabled: false

targets:
  influxdb:
    - name: "prod-influx-target"
      type: "influxdb"
      influxdb:
        version: 2
        url: "https://localhost:8087"
        token: "${INFLUX_TOKEN_TARGET}"
        org: "my-org"
        bucket: "metrics_target"
        retention_policy: ""
      ssl:
        enabled: true
        skip_verify: false

  mysql:
    - name: "mysql-backup"
      type: "mysql"
      host: "localhost"
      port: 3306
      user: "root"
      password: "${MYSQL_PASSWORD}"
      database: "metrics"
      ssl:
        enabled: false
        skip_verify: false

  tdengine:
    - name: "tdengine-backup"
      type: "tdengine"
      host: "localhost"
      port: 6030
      user: "root"
      password: "${TD_PASSWORD}"
      database: "metrics"
      tdengine:
        version: "3.x"
      ssl:
        enabled: false

tasks:
  - name: "mysql-to-influx"
    source: "prod-mysql"
    target: "prod-influx-target"
    mappings:
      - source_table: "cpu_metrics"
        target_measurement: "cpu_metrics"
        timestamp_column: "record_time"
        schema:
          tags:
            - source: "host_id"
              target: "host_id"
          fields:
            - source: "cpu_usage"
              target: "cpu_usage"
              type: "float"
            - source: "memory_usage"
              target: "memory_usage"
              type: "float"
        incremental:
          enabled: true
          timestamp_column: "record_time"

  - name: "influx-to-influx"
    source: "prod-influx"
    target: "prod-influx-target"
    mappings:
      - measurement: "cpu_metrics"
        target_measurement: "cpu_metrics_migrated"
        tag_filters:
          host: ["server1", "server2", "server3"]
        time_range:
          start: "2024-01-01T00:00:00Z"
          end: "2024-01-31T23:59:59Z"
        time_window: "168h"
        schema:
          tags:
            - source: "host"
              target: "host"
          fields:
            - source: "cpu_usage"
              target: "cpu_usage"
              type: "float"

  - name: "tdengine-to-influx"
    source: "prod-tdengine"
    target: "prod-influx-target"
    mappings:
      - measurement: "sensor_data"
        target_measurement: "sensor_data_migrated"
        subtable_pattern: "sensor_*"
        time_range:
          start: "2024-01-01T00:00:00Z"
          end: "2024-01-31T23:59:59Z"
        time_window: "168h"
        schema:
          tags:
            - source: "sensor_id"
              target: "sensor_id"
          fields:
            - source: "temperature"
              target: "temperature"
              type: "float"
            - source: "humidity"
              target: "humidity"
              type: "float"
